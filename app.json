{
  "expo": {
    "name": "Chiva",
    "slug": "chiva",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splashScreen.png",
      "resizeMode": "cover",
      "backgroundColor": "#06111f"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#06111f",
          "image": "./assets/splashScreen.png",
          "resizeMode": "cover",
          "enableFullScreenImage_legacy": true,
          "android": {
            "backgroundColor": "#06111f",
            "image": "./assets/splashScreen.png",
            "resizeMode": "cover"
          },
          "ios": {
            "backgroundColor": "#06111f",
            "image": "./assets/splashScreen.png",
            "resizeMode": "cover"
          }
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.swevazquez.chiva",
      "buildNumber": "1",
      "icon": "./assets/icon.png",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.swevazquez.chiva",
      "versionCode": 1,
      "statusBar": {
        "backgroundColor": "#06111f",
        "barStyle": "light-content",
        "translucent": false
      },
      "splash": {
        "image": "./assets/splashScreen.png",
        "resizeMode": "cover",
        "backgroundColor": "#06111f"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#06111f"
      }
    },
    "extra": {
      "eas": {
        "projectId": "98e2670d-29e9-418c-a8d0-ea1775a4be30"
      }
    }
  }
}
