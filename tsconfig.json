{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@app/*": [
        "app/*"
      ],
      "@data/*": [
        "data/*"
      ],
      "@domain/*": [
        "domain/*"
      ],
      "@features/*": [
        "features/*"
      ]
    }
  },
  "include": [
    "App.tsx",
    "app",
    "data",
    "domain",
    "features",
    "tests"
  ]
}
